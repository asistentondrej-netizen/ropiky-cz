---
import { getCollection, type CollectionEntry } from 'astro:content';

export interface Props {
  /** Kurátorský seznam ve formátu "clanky/slug" nebo "stranky/slug" */
  related?: string[];
  /** slug aktuální stránky (aby se nelinkovala sama na sebe ve fallbacku) */
  currentSlug?: string;
  /** Z jaké kolekce je aktuální stránka (pro fallback) */
  currentCollection?: 'stranky' | 'clanky';
  /** Nadpis */
  heading?: string;
}

const {
  related,
  currentSlug,
  currentCollection,
  heading = 'Související obsah',
} = Astro.props;

// Načti obě kolekce
const [allStranky, allClanky] = await Promise.all([
  getCollection('stranky'),
  getCollection('clanky', ({ data }) => !data.draft),
]);

type Card = {
  href: string;
  title: string;
  description: string;
  label: 'Stránka' | 'Článek';
  cover?: string;
};

function toCard(entry: CollectionEntry<'stranky'> | CollectionEntry<'clanky'>, collection: 'stranky' | 'clanky'): Card {
  if (collection === 'stranky') {
    const e = entry as CollectionEntry<'stranky'>;
    return {
      href: `/o-opevneni/${e.slug}`,
      title: e.data.title,
      description: e.data.description,
      label: 'Stránka',
    };
  }
  const e = entry as CollectionEntry<'clanky'>;
  return {
    href: `/clanky/${e.slug}`,
    title: e.data.title,
    description: e.data.description,
    label: 'Článek',
    cover: e.data.cover,
  };
}

let cards: Card[] = [];

if (related && related.length > 0) {
  // Kurátorský režim — následuj pořadí ze seznamu
  for (const ref of related) {
    const [col, slug] = ref.split('/');
    if (col === 'stranky') {
      const e = allStranky.find((x) => x.slug === slug);
      if (e) cards.push(toCard(e, 'stranky'));
    } else if (col === 'clanky') {
      const e = allClanky.find((x) => x.slug === slug);
      if (e) cards.push(toCard(e, 'clanky'));
    }
  }
} else if (currentCollection === 'stranky') {
  // Fallback pro stránky — všechny ostatní stránky seřazené podle order
  cards = allStranky
    .filter((e) => e.slug !== currentSlug)
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
    .map((e) => toCard(e, 'stranky'));
} else if (currentCollection === 'clanky') {
  // Fallback pro články — ostatní články seřazené od nejnovějších, max 6
  cards = allClanky
    .filter((e) => e.slug !== currentSlug)
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 6)
    .map((e) => toCard(e, 'clanky'));
}
---

{cards.length > 0 && (
  <nav class="related" aria-label={heading}>
    <h2 class="related__heading">{heading}</h2>
    <ul class="related__list">
      {cards.map((c) => (
        <li>
          <a class="related__item" href={c.href}>
            <span class={`related__label related__label--${c.label === 'Článek' ? 'article' : 'page'}`}>{c.label}</span>
            <span class="related__title">{c.title}</span>
            <span class="related__desc">{c.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .related {
    margin-top: var(--s6);
    padding-top: var(--s4);
    border-top: 2px solid var(--ink);
  }
  .related__heading {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .related__list {
    list-style: none;
    padding: 0;
    margin: var(--s3) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--s2);
  }
  .related__item {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--s3);
    background: var(--paper-dark);
    border: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: all 0.15s ease;
    height: 100%;
  }
  .related__item:hover {
    border-color: #7A3B2E;
    background: var(--paper);
    transform: translateY(-1px);
  }
  .related__label {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 2px;
    align-self: flex-start;
  }
  .related__label--page {
    background: #E8DFD3;
    color: #5A4B3A;
  }
  .related__label--article {
    background: #7A3B2E;
    color: #fff;
  }
  .related__title {
    font-weight: 700;
    font-size: 1rem;
    color: #7A3B2E;
    line-height: 1.3;
  }
  .related__desc {
    font-size: 0.875rem;
    color: var(--ink-light);
    line-height: 1.5;
  }
</style>

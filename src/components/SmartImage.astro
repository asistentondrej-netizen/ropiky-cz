---
// POZN: srcset dočasně VYPNUTO pro Wikimedia URL.
// Wikimedia rate-limituje (HTTP 429) on-demand generované thumbnail šířky,
// takže browser při výběru ze srcset narazí na 429 → obrázek se nezobrazí.
// Ponecháváme jen plain <img> s předem cached 1280px variantou (viz cover v .md).
// Performance optimalizace se vrátí, až převedeme covery na lokální kopie + Astro Image.

export interface Props {
  src: string;
  alt: string;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  class?: string;
  style?: string;
}

const {
  src,
  alt,
  loading = 'lazy',
  fetchpriority,
  width,
  height,
  class: className,
  style,
} = Astro.props;
---

<img
  src={src}
  alt={alt}
  loading={loading}
  fetchpriority={fetchpriority}
  width={width}
  height={height}
  class={className}
  style={style}
/>

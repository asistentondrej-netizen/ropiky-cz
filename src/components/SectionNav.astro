---
import { getCollection } from 'astro:content';

export interface Props {
  /** slug aktuální stránky, aby ji rozcestník nezobrazil */
  currentSlug: string;
  /** URL prefix (např. "/o-opevneni") */
  basePath: string;
  /** nadpis rozcestníku */
  heading?: string;
}

const { currentSlug, basePath, heading = 'Pokračujte v tématu' } = Astro.props;

// Všechny stránky seřazené podle order; odfiltrovat aktuální
const entries = (await getCollection('stranky'))
  .filter((e) => e.slug !== currentSlug)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

{entries.length > 0 && (
  <nav class="section-nav" aria-label={heading}>
    <h2 class="section-nav__heading">{heading}</h2>
    <ul class="section-nav__list">
      {entries.map((e) => (
        <li>
          <a class="section-nav__item" href={`${basePath}/${e.slug}`}>
            <span class="section-nav__title">{e.data.title}</span>
            <span class="section-nav__desc">{e.data.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .section-nav {
    margin-top: var(--s6);
    padding-top: var(--s4);
    border-top: 2px solid var(--ink);
  }
  .section-nav__heading {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .section-nav__list {
    list-style: none;
    padding: 0;
    margin: var(--s3) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--s2);
  }
  .section-nav__item {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--s3);
    background: var(--paper-dark);
    border: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: all 0.15s ease;
    height: 100%;
  }
  .section-nav__item:hover {
    border-color: #7A3B2E;
    background: var(--paper);
    transform: translateY(-1px);
  }
  .section-nav__title {
    font-weight: 700;
    font-size: 1rem;
    color: #7A3B2E;
    line-height: 1.3;
  }
  .section-nav__desc {
    font-size: 0.875rem;
    color: var(--ink-light);
    line-height: 1.5;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FortCard from '../../components/FortCard.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('pevnosti')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title, 'cs')
);

// Unikátní hodnoty pro filtry
const regions = [...new Set(all.map((p) => p.data.region))].sort((a, b) => a.localeCompare(b, 'cs'));
const types = [...new Set(all.map((p) => p.data.type))].sort();
const states = [...new Set(all.map((p) => p.data.state))].sort();
const total = all.length;

// Štítky pro UI (konzistentní s mapou)
const typeLabels: Record<string, string> = {
  'delostrelecka-tvrz': 'Dělostřelecká tvrz',
  'pechotni-srub': 'Pěchotní srub',
  'lo-vz-37': 'Řopík (LO vz. 37)',
  'lo-vz-36': 'LO vz. 36',
  'lo-vz-38': 'LO vz. 38 (Turek)',
  'objekt-vz-36': 'Objekt vz. 36',
};

const stateLabels: Record<string, string> = {
  muzeum: 'Muzeum',
  pristupny: 'Volně přístupný',
  zachovaly: 'Zachovalý',
  zavreny: 'Uzavřený',
  rozpadly: 'Rozpadlý',
  zničeny: 'Zničený',
  neznamy: 'Neznámý stav',
};

const countByType = (t: string) => all.filter((p) => p.data.type === t).length;
const countByState = (s: string) => all.filter((p) => p.data.state === s).length;
const countByRegion = (r: string) => all.filter((p) => p.data.region === r).length;
---

<BaseLayout
  title="Katalog pevností"
  description={`Databáze ${total} dokumentovaných objektů československého opevnění 1935–1938 s GPS souřadnicemi a fotografiemi.`}
>
  <header class="catalog-header">
    <div class="container">
      <div class="article-hero__breadcrumb" style="margin-bottom: var(--s3);">
        <a href="/">Úvod</a> / <span>Katalog pevností</span>
      </div>
      <h1>Katalog pevností</h1>
      <p class="article-hero__lead" style="margin-top: var(--s3);">
        Databáze <strong>{total}</strong> dokumentovaných objektů s GPS souřadnicemi, aktuálním stavem a fotografiemi.
        Filtrujte podle typu, stavu nebo úseku — nebo si objekty prohlédněte <a href="/mapa">v mapě</a>.
      </p>
    </div>
  </header>

  <section style="padding-top: var(--s4); padding-bottom: var(--s5);">
    <div class="container">

      <!-- Rozcestník / filtry — strukturovaný jako na mapě -->
      <div class="catalog-filters-box" id="filters">
        <div class="filter-group">
          <span class="filter-label">Typ:</span>
          <button class="filter-btn is-active" data-filter="type" data-value="all">
            Všechny ({total})
          </button>
          {types.map((t) => (
            <button class="filter-btn" data-filter="type" data-value={t}>
              {typeLabels[t] ?? t} ({countByType(t)})
            </button>
          ))}
        </div>

        <div class="filter-group">
          <span class="filter-label">Stav:</span>
          <button class="filter-btn is-active" data-filter="state" data-value="all">
            Všechny
          </button>
          {states.map((s) => (
            <button class="filter-btn" data-filter="state" data-value={s}>
              {stateLabels[s] ?? s} ({countByState(s)})
            </button>
          ))}
        </div>

        <div class="filter-group">
          <span class="filter-label">Kraj:</span>
          <button class="filter-btn is-active" data-filter="region" data-value="all">
            Všechny
          </button>
          {regions.map((r) => (
            <button class="filter-btn" data-filter="region" data-value={r}>
              {r} ({countByRegion(r)})
            </button>
          ))}
        </div>

        <div class="filter-footer">
          <span class="filter-counter">
            Zobrazeno: <strong id="visible-count">{total}</strong> z {total}
          </span>
          <button class="filter-reset" id="reset-filters" type="button">Resetovat filtry</button>
          <a href="/mapa" class="filter-mapa">Zobrazit v mapě →</a>
        </div>
      </div>

      <div class="pagination-top" id="pagination-top" hidden>
        <span class="pagination-info" id="pagination-info">Strana 1</span>
      </div>

      <p class="catalog-note">
        <strong>Pozn.:</strong> V <a href="/">typologii</a> najdete i <em>pancéřový zvon</em> (komponenta pěchotního srubu a tvrze, ne samostatný objekt)
        a <em>LO vz. 38 „Turek"</em> (dochovány jen 2 prototypy, zatím bez vlastních katalogových záznamů).
        U <em>dělostřeleckých tvrzí</em> zde najdete <strong>7 záznamů</strong> — 5 plně dokončených (Adam, Bouda, Hanička, Hůrka, Smolkov) a 2 rozestavěné, zpřístupněné jako muzea (Dobrošov, Stachelberg).
      </p>

      {all.length > 0 ? (
        <>
          <div class="fort-grid" id="fort-grid">
            {all.map((p) => (
              <div
                class="fort-grid-item"
                data-region={p.data.region}
                data-type={p.data.type}
                data-state={p.data.state}
              >
                <FortCard
                  title={p.data.title}
                  code={p.data.code}
                  line={p.data.line}
                  region={p.data.region}
                  type={p.data.type}
                  state={p.data.state}
                  href={`/katalog/${p.id.replace(/\.json$|\.yml$|\.yaml$/, '')}`}
                  imageUrl={p.data.photos?.[0]?.url}
                />
              </div>
            ))}
          </div>
          <div id="no-results" class="no-results" hidden>
            Žádná pevnost neodpovídá vybraným filtrům. Zkuste je <button type="button" id="no-results-reset" class="link-btn">resetovat</button>.
          </div>
          <nav class="pagination" id="pagination" aria-label="Stránkování katalogu" hidden>
            <button class="pagination-btn" id="page-prev" type="button" disabled aria-label="Předchozí strana">← Předchozí</button>
            <div class="pagination-pages" id="pagination-pages" role="group" aria-label="Čísla stránek"></div>
            <button class="pagination-btn" id="page-next" type="button" aria-label="Další strana">Další →</button>
          </nav>
        </>
      ) : (
        <p style="font-style: italic; color: var(--ink-light); padding: var(--s5) 0;">
          Katalog se postupně plní. Podívejte se brzy.
        </p>
      )}
    </div>
  </section>

  <style>
    .catalog-filters-box {
      background: var(--paper-dark);
      border: 1px solid var(--line);
      padding: var(--s3);
      margin-bottom: var(--s4);
      display: flex;
      flex-direction: column;
      gap: var(--s2);
    }
    .filter-group {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }
    .filter-label {
      font-weight: 600;
      font-size: 0.875rem;
      color: var(--ink);
      min-width: 60px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .filter-btn {
      background: var(--paper);
      border: 1px solid var(--line);
      padding: 6px 12px;
      font-size: 0.8125rem;
      font-family: inherit;
      color: var(--ink);
      cursor: pointer;
      transition: all 0.15s ease;
      border-radius: 0;
    }
    .filter-btn:hover {
      background: var(--paper-dark);
      border-color: #7A3B2E;
    }
    .filter-btn.is-active {
      background: #7A3B2E;
      color: white;
      border-color: #7A3B2E;
    }
    .filter-footer {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--s2);
      padding-top: var(--s2);
      margin-top: var(--s2);
      border-top: 1px solid var(--line-soft);
      font-size: 0.8125rem;
      color: var(--ink-light);
    }
    .filter-counter {
      font-family: monospace;
    }
    .filter-counter strong {
      color: var(--ink);
    }
    .filter-reset {
      background: transparent;
      border: 1px solid var(--line);
      padding: 4px 10px;
      font-size: 0.8125rem;
      font-family: inherit;
      color: var(--ink);
      cursor: pointer;
      border-radius: 0;
    }
    .filter-reset:hover {
      background: var(--paper);
      border-color: var(--ink);
    }
    .filter-mapa {
      margin-left: auto;
      color: #7A3B2E;
      font-weight: 600;
      text-decoration: none;
    }
    .filter-mapa:hover {
      text-decoration: underline;
    }
    .catalog-note {
      margin-top: var(--s3);
      margin-bottom: var(--s4);
      padding: var(--s3);
      background: var(--paper-dark);
      border-left: 3px solid #7A3B2E;
      font-size: 0.875rem;
      color: var(--ink-light);
      line-height: 1.6;
    }
    .catalog-note strong { color: var(--ink); }
    .catalog-note a { color: #7A3B2E; font-weight: 600; }
    .no-results {
      padding: var(--s5) 0;
      text-align: center;
      font-style: italic;
      color: var(--ink-light);
    }
    .link-btn {
      background: none;
      border: none;
      padding: 0;
      color: #7A3B2E;
      cursor: pointer;
      font: inherit;
      text-decoration: underline;
    }
    .pagination-top {
      margin-bottom: var(--s3);
      font-size: 0.875rem;
      color: var(--ink-light);
      font-family: monospace;
    }
    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--s2);
      margin-top: var(--s4);
      padding-top: var(--s3);
      border-top: 1px solid var(--line-soft);
      flex-wrap: wrap;
    }
    .pagination-btn {
      background: var(--paper);
      border: 1px solid var(--line);
      padding: 8px 14px;
      font-size: 0.875rem;
      font-family: inherit;
      color: var(--ink);
      cursor: pointer;
      border-radius: 0;
    }
    .pagination-btn:hover:not(:disabled) {
      background: var(--paper-dark);
      border-color: #7A3B2E;
    }
    .pagination-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .pagination-pages {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
    }
    .pagination-page {
      background: var(--paper);
      border: 1px solid var(--line);
      padding: 6px 12px;
      font-size: 0.875rem;
      font-family: monospace;
      color: var(--ink);
      cursor: pointer;
      border-radius: 0;
      min-width: 36px;
    }
    .pagination-page:hover {
      background: var(--paper-dark);
      border-color: #7A3B2E;
    }
    .pagination-page.is-active {
      background: #7A3B2E;
      color: white;
      border-color: #7A3B2E;
      font-weight: 600;
    }
    .pagination-ellipsis {
      padding: 6px 4px;
      color: var(--ink-light);
    }

    @media (max-width: 640px) {
      .filter-group { flex-direction: column; align-items: flex-start; }
      .filter-label { min-width: auto; }
      .filter-footer { flex-direction: column; align-items: flex-start; }
      .filter-mapa { margin-left: 0; }
    }
  </style>

  <script>
    const PER_PAGE = 50;
    const filterState: Record<string, string> = { type: 'all', state: 'all', region: 'all' };
    let currentPage = 1;

    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items = Array.from(document.querySelectorAll<HTMLElement>('#fort-grid .fort-grid-item'));
    const counterEl = document.getElementById('visible-count');
    const noResultsEl = document.getElementById('no-results');
    const gridEl = document.getElementById('fort-grid');
    const resetBtn = document.getElementById('reset-filters');
    const noResultsResetBtn = document.getElementById('no-results-reset');
    const paginationEl = document.getElementById('pagination');
    const pagesEl = document.getElementById('pagination-pages');
    const prevBtn = document.getElementById('page-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('page-next') as HTMLButtonElement | null;
    const paginationTopEl = document.getElementById('pagination-top');
    const paginationInfoEl = document.getElementById('pagination-info');

    function getMatchedItems() {
      return items.filter((item) => {
        const matchType = filterState.type === 'all' || item.dataset.type === filterState.type;
        const matchState = filterState.state === 'all' || item.dataset.state === filterState.state;
        const matchRegion = filterState.region === 'all' || item.dataset.region === filterState.region;
        return matchType && matchState && matchRegion;
      });
    }

    function renderPagination(totalPages: number) {
      if (!pagesEl || !paginationEl || !prevBtn || !nextBtn) return;
      if (totalPages <= 1) {
        paginationEl.setAttribute('hidden', '');
        return;
      }
      paginationEl.removeAttribute('hidden');
      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage === totalPages;
      pagesEl.innerHTML = '';
      // Sousedy ±2, vždy zobraz 1 a last, ellipsis pokud mezera
      const pages = new Set<number>([1, totalPages, currentPage - 1, currentPage, currentPage + 1]);
      const validPages = [...pages].filter((p) => p >= 1 && p <= totalPages).sort((a, b) => a - b);
      let prev = 0;
      for (const p of validPages) {
        if (p - prev > 1) {
          const ell = document.createElement('span');
          ell.className = 'pagination-ellipsis';
          ell.textContent = '…';
          pagesEl.appendChild(ell);
        }
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'pagination-page' + (p === currentPage ? ' is-active' : '');
        btn.textContent = String(p);
        btn.setAttribute('aria-label', `Strana ${p}`);
        if (p === currentPage) btn.setAttribute('aria-current', 'page');
        btn.addEventListener('click', () => goToPage(p));
        pagesEl.appendChild(btn);
        prev = p;
      }
    }

    function render() {
      const matched = getMatchedItems();
      const total = matched.length;
      const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
      if (currentPage > totalPages) currentPage = totalPages;

      // Skryj nejprve všechno
      items.forEach((it) => (it.style.display = 'none'));
      // Zobraz jen položky na aktuální straně z filtrovaných
      const from = (currentPage - 1) * PER_PAGE;
      const to = from + PER_PAGE;
      matched.slice(from, to).forEach((it) => (it.style.display = ''));

      if (counterEl) counterEl.textContent = String(total);
      if (noResultsEl && gridEl) {
        if (total === 0) {
          noResultsEl.removeAttribute('hidden');
          gridEl.style.display = 'none';
        } else {
          noResultsEl.setAttribute('hidden', '');
          gridEl.style.display = '';
        }
      }
      if (paginationTopEl && paginationInfoEl) {
        if (total > PER_PAGE) {
          paginationTopEl.removeAttribute('hidden');
          const shownFrom = from + 1;
          const shownTo = Math.min(to, total);
          paginationInfoEl.textContent = `Strana ${currentPage} z ${totalPages} — zobrazeno ${shownFrom}–${shownTo} z ${total}`;
        } else {
          paginationTopEl.setAttribute('hidden', '');
        }
      }
      renderPagination(totalPages);
    }

    function goToPage(p: number) {
      currentPage = p;
      render();
      // Scroll na začátek filtrů (aby bylo vidět od kolik-kam)
      const filtersEl = document.getElementById('filters');
      if (filtersEl) filtersEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) goToPage(currentPage - 1);
    });
    nextBtn?.addEventListener('click', () => {
      const matched = getMatchedItems();
      const totalPages = Math.max(1, Math.ceil(matched.length / PER_PAGE));
      if (currentPage < totalPages) goToPage(currentPage + 1);
    });

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter!;
        const value = btn.dataset.value!;
        btn.parentElement!.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        filterState[filter] = value;
        currentPage = 1;
        render();
      });
    });

    function resetAll() {
      (['type', 'state', 'region'] as const).forEach((f) => {
        filterState[f] = 'all';
      });
      buttons.forEach((b) => {
        b.classList.toggle('is-active', b.dataset.value === 'all');
      });
      currentPage = 1;
      render();
    }

    resetBtn?.addEventListener('click', resetAll);
    noResultsResetBtn?.addEventListener('click', resetAll);

    // Inicializace
    render();
  </script>
</BaseLayout>

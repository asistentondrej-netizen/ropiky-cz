---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const linie = (await getCollection('linie')).sort((a, b) => a.data.order - b.data.order);

const totalObjektu = linie.reduce((acc, l) => acc + (l.data.pocet_objektu ?? 0), 0);
const totalKm = linie.reduce((acc, l) => acc + (l.data.delka_km ?? 0), 0);
---

<BaseLayout
  title="Obranné linie ŘOP"
  description="Přehled obranných linií československého opevnění 1935–1938. Od Ostravska přes Orlické hory a Krkonoše po jižní Moravu a Bratislavské předmostí — 11 úseků, přibližně 1 300 km hranice, přes 1 400 dokumentovaných objektů."
>
  <header class="catalog-header">
    <div class="container">
      <div class="article-hero__breadcrumb" style="margin-bottom: var(--s3);">
        <a href="/">Úvod</a> / <span>Linie</span>
      </div>
      <h1>Obranné linie ŘOP</h1>
      <p class="article-hero__lead" style="margin-top: var(--s3);">
        Československé opevnění nebylo jedna souvislá linie — šlo o {linie.length} různorodých úseků
        s vlastní logikou, tempem stavby a dnešním stavem. Od prvních betonáží v Ostravsku v roce 1935
        po urgentní dobetonování jižní Moravy po Anschlussu v roce 1938.
      </p>

      <div class="line-stats">
        <div class="line-stat">
          <strong>{linie.length}</strong>
          <span>dokumentovaných úseků</span>
        </div>
        <div class="line-stat">
          <strong>~{totalKm.toLocaleString('cs-CZ')} km</strong>
          <span>celkové délky</span>
        </div>
        <div class="line-stat">
          <strong>~{totalObjektu.toLocaleString('cs-CZ')}</strong>
          <span>objektů v přehledu</span>
        </div>
      </div>
    </div>
  </header>

  <section>
    <div class="container">
      <div class="linie-grid">
        {linie.map((l) => (
          <a href={`/linie/${l.slug}`} class="line-card">
            <div class="line-card__region">{l.data.region}</div>
            <h2 class="line-card__title">{l.data.title}</h2>
            <p class="line-card__desc">{l.data.description}</p>
            <div class="line-card__meta">
              {l.data.delka_km && <span>{l.data.delka_km} km</span>}
              {l.data.pocet_objektu && <span>{l.data.pocet_objektu} objektů</span>}
              {l.data.obdobi_stavby && <span>{l.data.obdobi_stavby}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .line-stats {
      display: flex;
      flex-wrap: wrap;
      gap: var(--s4);
      margin-top: var(--s4);
      padding-top: var(--s3);
      border-top: 1px solid var(--line);
    }
    .line-stat {
      display: flex;
      flex-direction: column;
    }
    .line-stat strong {
      font-size: 1.75rem;
      font-family: var(--font-display, serif);
      color: #7A3B2E;
      line-height: 1;
    }
    .line-stat span {
      font-size: 0.875rem;
      color: var(--ink-light);
      margin-top: 4px;
    }
    .linie-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: var(--s3);
    }
    .line-card {
      display: flex;
      flex-direction: column;
      gap: var(--s2);
      padding: var(--s3);
      background: var(--paper);
      border: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
      transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .line-card:hover {
      transform: translateY(-2px);
      border-color: #7A3B2E;
      box-shadow: 0 6px 20px rgba(0,0,0,0.07);
    }
    .line-card__region {
      font-size: 0.75rem;
      color: var(--ink-light);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .line-card__title {
      margin: 0;
      font-size: 1.35rem;
      color: var(--ink);
      line-height: 1.25;
    }
    .line-card__desc {
      margin: 0;
      font-size: 0.9375rem;
      color: var(--ink);
      line-height: 1.55;
    }
    .line-card__meta {
      margin-top: auto;
      padding-top: var(--s2);
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      font-size: 0.8125rem;
      color: var(--ink-light);
      border-top: 1px dashed var(--line);
    }
    .line-card__meta span + span::before {
      content: '·';
      margin-right: 12px;
      color: var(--line);
    }
  </style>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const linie = (await getCollection('linie')).sort((a, b) => a.data.order - b.data.order);

// Historická celostátní čísla ŘOP (zdroj: Aron/Hrůbek, Stehlík, Dubánek)
// Shodné s /o-opevneni/co-je-rop/ — single source of truth
const HISTORY_CELKEM_PLAN_TO = 1276;
const HISTORY_CELKEM_PLAN_LO = 15463;
const HISTORY_CELKEM_PLAN = HISTORY_CELKEM_PLAN_TO + HISTORY_CELKEM_PLAN_LO; // 16 739
const HISTORY_CELKEM_REAL_TO = 263;
const HISTORY_CELKEM_REAL_LO = 10012; // 9 148 vz.37 + 864 vz.36
const HISTORY_CELKEM_REAL = HISTORY_CELKEM_REAL_TO + HISTORY_CELKEM_REAL_LO; // 10 275
const HISTORY_CELKEM_KM = 1466;

// Součet za 12 dokumentovaných linií (kontrolní)
const sumaPlanovano = linie.reduce((acc, l) => acc + (l.data.pocet_planovano ?? l.data.pocet_objektu ?? 0), 0);
const sumaRealizovano = linie.reduce((acc, l) => acc + (l.data.pocet_realizovano ?? l.data.pocet_objektu ?? 0), 0);
const sumaKm = linie.reduce((acc, l) => acc + (l.data.delka_km ?? 0), 0);
---

<BaseLayout
  title="Obranné linie ŘOP"
  description={`Přehled ${linie.length} obranných linií československého opevnění 1935–1938. Plánováno 1 276 objektů těžkého opevnění a 15 463 lehkého opevnění; do mobilizace v září 1938 postaveno 263 TO a přibližně 10 000 LO.`}
>
  <header class="catalog-header">
    <div class="container">
      <div class="article-hero__breadcrumb" style="margin-bottom: var(--s3);">
        <a href="/">Úvod</a> / <span>Linie</span>
      </div>
      <h1>Obranné linie ŘOP</h1>
      <p class="article-hero__lead" style="margin-top: var(--s3);">
        Československé opevnění nebylo jedna souvislá linie — šlo o {linie.length} různorodých úseků
        s vlastní logikou, tempem stavby a dnešním stavem. Od prvních betonáží v Ostravsku v roce 1935
        po urgentní dobetonování jižní Moravy a jižního Slovenska po Anschlussu v roce 1938.
      </p>

      <div class="line-stats">
        <div class="line-stat">
          <strong>~{HISTORY_CELKEM_KM.toLocaleString('cs-CZ')} km</strong>
          <span>hlavní obranná linie</span>
        </div>
        <div class="line-stat">
          <strong>{HISTORY_CELKEM_PLAN.toLocaleString('cs-CZ')}</strong>
          <span>objektů plánováno celkem</span>
        </div>
        <div class="line-stat line-stat--accent">
          <strong>~{HISTORY_CELKEM_REAL.toLocaleString('cs-CZ')}</strong>
          <span>postaveno do 9/1938</span>
        </div>
        <div class="line-stat">
          <strong>{linie.length}</strong>
          <span>obranných úseků v přehledu</span>
        </div>
      </div>

      <aside class="methodology-note">
        <strong>Metodika:</strong> Horní čísla jsou celostátní historické údaje pro celé ČSR — plán zahrnuje
        {' '}{HISTORY_CELKEM_PLAN_TO.toLocaleString('cs-CZ')} objektů těžkého opevnění a {HISTORY_CELKEM_PLAN_LO.toLocaleString('cs-CZ')}
        {' '}objektů lehkého opevnění (vz. 37 + vz. 36); do mobilizace 23.–30. 9. 1938 bylo postaveno
        {' '}{HISTORY_CELKEM_REAL_TO} TO a přibližně {HISTORY_CELKEM_REAL_LO.toLocaleString('cs-CZ')} LO
        {' '}(z toho 9 148 řopíků LO vz. 37 a 864 LO vz. 36).
        <br/><br/>
        <strong>V tomto přehledu 12 dokumentovaných linií</strong> je zachyceno ~{sumaPlanovano.toLocaleString('cs-CZ')} plánovaných
        a ~{sumaRealizovano.toLocaleString('cs-CZ')} postavených objektů ({Math.round(sumaRealizovano / HISTORY_CELKEM_REAL * 100)} % celostátní reality)
        po délce ~{sumaKm.toLocaleString('cs-CZ')} km. Chybějící objekty tvoří menší a sekundární úseky mimo 12 hlavních linií
        (zejména plně zdokumentovaný rozpočet pro Slovensko, drobné vnitrozemské příčky a pozdější plánovací fáze).
        V katalogu je dnes dochováno 6 092 objektů — rozdíl vůči postaveným tvoří demolice 50.–60. let,
        zatopení přehradami a ztráty dokumentace.
        <br/><br/>
        <em>Zdroje:</em> Aron/Hrůbek <em>Československé opevnění 1935–1938</em>, Stehlík <em>Lexikon těžkých objektů</em>,
        Dubánek <em>Opevnění Československa</em>, aggregator <a href="https://www.prazskacara.cz/" target="_blank" rel="noopener">prazskacara.cz</a>.
      </aside>
    </div>
  </header>

  <section>
    <div class="container">
      <div class="linie-grid">
        {linie.map((l) => (
          <a href={`/linie/${l.slug}`} class="line-card">
            <div class="line-card__region">{l.data.region}</div>
            <h2 class="line-card__title">{l.data.title}</h2>
            <p class="line-card__desc">{l.data.description}</p>
            <div class="line-card__meta">
              {l.data.delka_km ? <span>{l.data.delka_km} km</span> : null}
              {l.data.pocet_planovano || l.data.pocet_realizovano ? (
                <span>
                  {l.data.pocet_realizovano ?? l.data.pocet_objektu} / {l.data.pocet_planovano} objektů
                </span>
              ) : l.data.pocet_objektu ? (
                <span>{l.data.pocet_objektu} objektů</span>
              ) : null}
              {l.data.obdobi_stavby ? <span>{l.data.obdobi_stavby}</span> : null}
            </div>
            {l.data.pocet_planovano && l.data.pocet_realizovano ? (
              <div class="line-card__progress" title={`Postaveno ${l.data.pocet_realizovano} z plánovaných ${l.data.pocet_planovano}`}>
                <div
                  class="line-card__progress-bar"
                  style={`width: ${Math.min(100, Math.round((l.data.pocet_realizovano / l.data.pocet_planovano) * 100))}%`}
                ></div>
                <span class="line-card__progress-label">
                  {Math.round((l.data.pocet_realizovano / l.data.pocet_planovano) * 100)} % dokončeno do 9/1938
                </span>
              </div>
            ) : null}
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .line-stats {
      display: flex;
      flex-wrap: wrap;
      gap: var(--s4);
      margin-top: var(--s4);
      padding-top: var(--s3);
      border-top: 1px solid var(--line);
    }
    .line-stat {
      display: flex;
      flex-direction: column;
    }
    .line-stat strong {
      font-size: 1.75rem;
      font-family: var(--font-display, serif);
      color: var(--ink);
      line-height: 1;
    }
    .line-stat--accent strong {
      color: #7A3B2E;
    }
    .line-stat span {
      font-size: 0.875rem;
      color: var(--ink-light);
      margin-top: 4px;
    }
    .methodology-note {
      margin-top: var(--s3);
      padding: var(--s3);
      background: var(--paper-dark);
      border-left: 3px solid #7A3B2E;
      font-size: 0.875rem;
      color: var(--ink-light);
      line-height: 1.6;
    }
    .methodology-note strong {
      color: var(--ink);
    }
    .line-card__progress {
      position: relative;
      margin-top: var(--s2);
      height: 6px;
      background: var(--line-soft, #eee);
      border-radius: 0;
      overflow: hidden;
    }
    .line-card__progress-bar {
      height: 100%;
      background: #7A3B2E;
      transition: width 0.3s ease;
    }
    .line-card__progress-label {
      position: absolute;
      top: 100%;
      left: 0;
      margin-top: 4px;
      font-size: 0.75rem;
      color: var(--ink-light);
      font-family: monospace;
    }
    .linie-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: var(--s3);
    }
    .line-card {
      display: flex;
      flex-direction: column;
      gap: var(--s2);
      padding: var(--s3);
      padding-bottom: calc(var(--s3) + 20px);
      background: var(--paper);
      border: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
      transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .line-card:hover {
      transform: translateY(-2px);
      border-color: #7A3B2E;
      box-shadow: 0 6px 20px rgba(0,0,0,0.07);
    }
    .line-card__region {
      font-size: 0.75rem;
      color: var(--ink-light);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .line-card__title {
      margin: 0;
      font-size: 1.35rem;
      color: var(--ink);
      line-height: 1.25;
    }
    .line-card__desc {
      margin: 0;
      font-size: 0.9375rem;
      color: var(--ink);
      line-height: 1.55;
    }
    .line-card__meta {
      margin-top: auto;
      padding-top: var(--s2);
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      font-size: 0.8125rem;
      color: var(--ink-light);
      border-top: 1px dashed var(--line);
    }
    .line-card__meta span + span::before {
      content: '·';
      margin-right: 12px;
      color: var(--line);
    }
  </style>
</BaseLayout>

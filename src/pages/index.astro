---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FortCard from '../components/FortCard.astro';
import JsonLd from '../components/JsonLd.astro';
import { organization, webSite } from '../lib/schema';
import SmartImage from '../components/SmartImage.astro';
import { CARD_SIZES } from '../lib/wikimedia';

const obtiznostLabel: Record<string, string> = {
  snadna: 'Snadná',
  stredni: 'Střední',
  narocna: 'Náročná',
};
const rocniLabelShort: Record<string, string> = {
  celorocne: 'Celoročně',
  'sezonne-duben-rijen': 'Duben–říjen',
  'jen-leto': 'Jen v létě',
};

// Typologie sorted by order
const typologie = (await getCollection('typologie')).sort(
  (a, b) => a.data.order - b.data.order
);

// Rozdělení: hlavní typy objektů vs. speciální (komponenta, prototyp)
const typMain = typologie.filter((t) => !t.data.isComponent && !t.data.isPrototype);
const typSpecial = typologie.filter((t) => t.data.isComponent || t.data.isPrototype);

// Výběr pevností pro úvodní stranu — typově různorodá showcase
// (tvrze + sruby + řopíky), preferuj objekty s fotkou.
const all = await getCollection('pevnosti');
const withPhoto = all.filter((p) => p.data.photos && p.data.photos.length > 0);

const statePriority: Record<string, number> = {
  muzeum: 1, pristupny: 2, zachovaly: 3, zavreny: 4, rozpadly: 5, 'zničeny': 6, neznamy: 7,
};
const pickByType = (typeKey: string, n: number) =>
  withPhoto
    .filter((p) => p.data.type === typeKey)
    .sort((a, b) => (statePriority[a.data.state] ?? 99) - (statePriority[b.data.state] ?? 99))
    .slice(0, n);

// 3 tvrze + 2 sruby + 1 řopík = 6 různorodých objektů
const pevnosti = [
  ...pickByType('delostrelecka-tvrz', 3),
  ...pickByType('pechotni-srub', 2),
  ...pickByType('lo-vz-37', 1),
];

// Nejnovější články
const clanky = (await getCollection('clanky', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

// Tematické cesty — 3 nejlepší entry pointy (1denní / 2denní), preferuj ty s cover fotkou
const cestyAll = (await getCollection('cesty', ({ data }) => !data.draft))
  .filter((c) => c.data.cover)
  .sort((a, b) => a.data.delka_dni - b.data.delka_dni);
const cesty = cestyAll.slice(0, 3);

// Linie, Výzbroj, Tvrze — pro nové preview sekce
const linie = (await getCollection('linie')).sort((a, b) => a.data.order - b.data.order).slice(0, 6);
const vyzbroj = (await getCollection('vyzbroj')).sort((a, b) => a.data.order - b.data.order).slice(0, 6);
const tvrze = (await getCollection('tvrze')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Ropiky.cz"
  description="Referenční portál o československém opevnění z let 1935–1938. Typologie, katalog pevností, historie a mapy."
>
  <JsonLd data={[organization(), webSite()]} />
  <!-- HERO -->
  <section class="hero hero--with-illustration">
    <div class="hero__content">
      <span class="hero__overline">Encyklopedie · 1935–1938</span>
      <h1>Pevnosti, které nikdy nepadly v boji.</h1>
      <p class="hero__lead">
        Během necelých čtyř let postavilo Československo jeden z nejhustších systémů opevnění v Evropě.
        Dnes po něm zůstaly tisíce betonových stop napříč historickými zeměmi.
      </p>
      <div class="hero__actions">
        <a href="/katalog" class="btn btn--primary">Prozkoumat katalog</a>
        <a href="/cesty" class="btn btn--ghost">Naplánovat výlet</a>
        <a href="/o-opevneni/co-je-rop" class="btn btn--ghost">Co je ŘOP?</a>
      </div>

      <aside class="hero__stats" aria-label="Základní čísla">
        <dl>
          <dt>Postaveno do 9/1938</dt><dd>~ 10 000 objektů</dd>
          <dt>Hlavní obranná linie</dt><dd>~ 1 466 km</dd>
          <dt>Období výstavby</dt><dd>1935–1938</dd>
          <dt>Dělostřeleckých tvrzí</dt><dd>9 zahájeno, 5 dokončeno</dd>
        </dl>
      </aside>
    </div>
    <div class="hero__illustration" aria-hidden="true">
      <img src="/img/hero-ropik.svg" alt="" loading="eager" />
    </div>
  </section>

  <!-- TYPOLOGIE -->
  <section id="typologie">
    <div class="container">
      <header class="section-header">
        <span class="section-header__num">I.</span>
        <div class="section-header__content">
          <h2>Typologie opevnění</h2>
          <p>Od lehkých objektů až po dělostřelecké tvrze</p>
        </div>
      </header>

      {(() => {
        const iconMap = {
          'lo-vz-36': '/img/typ-lo-vz-36.svg',
          'lo-vz-37': '/img/typ-lo-vz-37.svg',
          'lo-vz-38': '/img/typ-lo-vz-38.svg',
          'pechotni-srub': '/img/typ-pechotni-srub.svg',
          'delostrelecka-tvrz': '/img/typ-delostrelecka-tvrz.svg',
          'pancerovy-zvon': '/img/typ-pancerovy-zvon.svg',
          'kopule-pozorovaci': '/img/typ-kopule-pozorovaci.svg',
        };
        const cardFor = (t) => {
          const icon = iconMap[t.slug] || null;
          const isComp = t.data.isComponent === true;
          const isProto = t.data.isPrototype === true;
          const cls = [
            'typology-card',
            isComp ? 'typology-card--component' : '',
            isProto ? 'typology-card--prototype' : '',
          ].filter(Boolean).join(' ');
          const badge = isComp ? 'Komponenta' : (isProto ? 'Prototyp' : null);
          const badgeTitle = isComp
            ? 'Komponenta — součást pěchotního srubu nebo tvrze, ne samostatný objekt'
            : 'Prototyp — jen 2 postavené objekty, bez sériové výroby';
          return (
            <a href={`/typologie/${t.slug}`} class={cls}>
              {badge && (<span class="typology-card__badge" title={badgeTitle}>{badge}</span>)}
              {icon && (
                <div class="typology-card__icon" aria-hidden="true">
                  <img src={icon} alt="" loading="lazy" />
                </div>
              )}
              <div class="typology-card__code">{t.data.code}</div>
              <h3>{t.data.title}</h3>
              <div class="typology-card__meta">
                <span>{t.data.period}</span>
                {t.data.builtCount && <span>{t.data.builtCount.toLocaleString('cs-CZ')} ks</span>}
              </div>
              <p>{t.data.description}</p>
            </a>
          );
        };
        return (
          <>
            <div class="typology-grid">
              {typMain.map(cardFor)}
            </div>

            {typSpecial.length > 0 && (
              <div class="typology-special">
                <h3 class="typology-special__title">Speciální případy</h3>
                <p class="typology-special__lead">
                  Komponenty pevností a nesériové prototypy — v <a href="/katalog">katalogu</a> ani v <a href="/mapa">mapě</a> je samostatně nenajdete.
                </p>
                <div class="typology-grid typology-grid--special">
                  {typSpecial.map(cardFor)}
                </div>
              </div>
            )}
          </>
        );
      })()}
    </div>
  </section>

  <!-- KATALOG PREVIEW -->
  <section id="katalog-preview" style="padding-top: 0;">
    <div class="container">
      <header class="section-header">
        <span class="section-header__num">II.</span>
        <div class="section-header__content">
          <h2>Katalog pevností</h2>
          <p>Dokumentované objekty napříč historickými zeměmi</p>
        </div>
      </header>

      {pevnosti.length > 0 ? (
        <div class="fort-grid">
          {pevnosti.map((p) => (
            <FortCard
              title={p.data.title}
              code={p.data.code}
              line={p.data.line}
              region={p.data.region}
              type={p.data.type}
              state={p.data.state}
              imageUrl={p.data.photos?.[0]?.url}
              href={`/katalog/${p.id.replace(/\.json$|\.yml$|\.yaml$/, '')}`}
            />
          ))}
        </div>
      ) : (
        <p style="font-style: italic; color: var(--ink-light);">
          Databáze se postupně doplňuje. Sledujte <a href="/clanky">články</a> pro novinky.
        </p>
      )}

      <div style="text-align: center; margin-top: var(--s5);">
        <a href="/katalog" class="btn btn--link">Zobrazit celý katalog →</a>
      </div>
    </div>
  </section>

  <!-- CESTY -->
  {cesty.length > 0 && (
    <section id="cesty-preview">
      <div class="container">
        <header class="section-header">
          <span class="section-header__num">III.</span>
          <div class="section-header__content">
            <h2>Tematické cesty</h2>
            <p>Hotové itineráře pro víkendy i jednodenní výlety</p>
          </div>
        </header>

        <div class="home-cesty-grid">
          {cesty.map((c) => (
            <a href={`/cesty/${c.slug}`} class="home-cesta-card">
              <div class="home-cesta-card__thumb">
                <SmartImage src={c.data.cover} alt={c.data.title} sizes={CARD_SIZES} loading="lazy" />
                <div class="home-cesta-card__duration">
                  {c.data.delka_dni} {c.data.delka_dni === 1 ? 'den' : c.data.delka_dni < 5 ? 'dny' : 'dní'}
                </div>
              </div>
              <div class="home-cesta-card__body">
                <div class="home-cesta-card__meta">
                  <span>{c.data.region}</span>
                  <span> · </span>
                  <span>{obtiznostLabel[c.data.obtiznost]}</span>
                  <span> · </span>
                  <span>{rocniLabelShort[c.data.rocni]}</span>
                </div>
                <h3>{c.data.title}</h3>
                <p>{c.data.description}</p>
              </div>
            </a>
          ))}
        </div>

        <div style="text-align: center; margin-top: var(--s5);">
          <a href="/cesty" class="btn btn--link">Všechny tematické cesty →</a>
        </div>
      </div>
    </section>
  )}

  <!-- LINIE + VÝZBROJ + TVRZE -->
  <section>
    <div class="container">
      <header class="section-header">
        <span class="section-header__num">IV.</span>
        <div class="section-header__content">
          <h2>Prozkoumat dál</h2>
          <p>Tři tematické vstupy do struktur ŘOP</p>
        </div>
      </header>

      <div class="explore-grid">
        <a href="/linie" class="explore-card">
          <div class="explore-card__label">Obranné linie</div>
          <h3>11 úseků napříč ČSR</h3>
          <p>Od Ostravska přes Orlicko-Kladsko a Krkonoše po Bratislavské předmostí — každá linie s vlastní taktikou a osudem.</p>
          <ul class="explore-card__list">
            {linie.slice(0, 4).map((l) => (<li>{l.data.title}</li>))}
          </ul>
          <span class="explore-card__link">Všech 11 linií →</span>
        </a>

        <a href="/vyzbroj" class="explore-card">
          <div class="explore-card__label">Výzbroj pevností</div>
          <h3>Zbraně, které nikdy nevystřelily</h3>
          <p>ZB vz. 37 (předchůdce BESA), pevnostní houfnice 10 cm, pancéřové zvony Škoda/Vítkovice a nejvzácnější plamenomet typ F.</p>
          <ul class="explore-card__list">
            {vyzbroj.slice(0, 4).map((v) => (<li>{v.data.title}</li>))}
          </ul>
          <span class="explore-card__link">Celá výzbroj →</span>
        </a>

        <a href="/tvrze" class="explore-card">
          <div class="explore-card__label">Dělostřelecké tvrze</div>
          <h3>Deep-dive do 5 tvrzí</h3>
          <p>Bouda, Hanička, Dobrošov, Stachelberg, Adam, Smolkov. Od plně dokončené po rozestavěnou — a Hanička jako atomový kryt 70. let.</p>
          <ul class="explore-card__list">
            {tvrze.slice(0, 4).map((t) => (<li>{t.data.title}</li>))}
          </ul>
          <span class="explore-card__link">Všechny tvrze →</span>
        </a>
      </div>

      <div class="secondary-links">
        <a href="/casova-osa" class="secondary-link">
          <strong>Časová osa 1918–1945</strong>
          <span>40 událostí od vzniku ČSR po konec války</span>
        </a>
        <a href="/glosar" class="secondary-link">
          <strong>Glosář pevnostních pojmů</strong>
          <span>100+ hesel z oblasti opevnění</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section>
    <div class="container">
      <div class="features">
        <div class="feature">
          <div class="feature__num">I.</div>
          <h3>Ověřené prameny</h3>
          <p>Každý článek odkazuje na odbornou literaturu, archivy a terénní průzkumy.</p>
        </div>
        <div class="feature">
          <div class="feature__num">II.</div>
          <h3>Interaktivní mapa</h3>
          <p>Všechny katalogizované objekty najdete v mapě s GPS souřadnicemi.</p>
        </div>
        <div class="feature">
          <div class="feature__num">III.</div>
          <h3>Otevřený obsah</h3>
          <p>Texty a fotografie pod licencí CC BY-SA 4.0. Sdílejte, citujte, rozšiřujte.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG / AKTUALITY -->
  {clanky.length > 0 && (
    <section>
      <div class="container">
        <header class="section-header">
          <span class="section-header__num">V.</span>
          <div class="section-header__content">
            <h2>Aktuality</h2>
            <p>Nové články, objevené objekty, výzkumné zápisky</p>
          </div>
        </header>

        <div class="article-list">
          {clanky.map((c) => (
            <a href={`/clanky/${c.slug}`} class="article-item">
              <div>
                <div class="article-item__date">
                  {c.data.pubDate.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' })}
                </div>
              </div>
              <div>
                <h3>{c.data.title}</h3>
                <p>{c.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <style>
    .explore-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--s3);
    }
    .explore-card {
      display: flex;
      flex-direction: column;
      gap: var(--s2);
      padding: var(--s3);
      background: var(--paper);
      border: 1px solid var(--line);
      border-top: 3px solid #7A3B2E;
      text-decoration: none;
      color: inherit;
      transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .explore-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.07);
    }
    .explore-card:nth-child(2) { border-top-color: #2D5F3F; }
    .explore-card:nth-child(3) { border-top-color: #8B6F47; }
    .explore-card__label {
      font-size: 0.75rem;
      color: var(--ink-light);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .explore-card h3 {
      margin: 0;
      font-size: 1.2rem;
      color: var(--ink);
      line-height: 1.3;
    }
    .explore-card p {
      margin: 0;
      font-size: 0.9375rem;
      color: var(--ink);
      line-height: 1.55;
    }
    .explore-card__list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .explore-card__list li {
      font-size: 0.875rem;
      color: var(--ink-light);
      padding-left: 14px;
      position: relative;
    }
    .explore-card__list li::before {
      content: '›';
      position: absolute;
      left: 0;
      color: #7A3B2E;
      font-weight: 700;
    }
    .explore-card__link {
      margin-top: auto;
      padding-top: var(--s2);
      border-top: 1px dashed var(--line);
      font-weight: 600;
      color: #7A3B2E;
      font-size: 0.9375rem;
    }
    .secondary-links {
      margin-top: var(--s4);
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--s2);
    }
    .secondary-link {
      display: flex;
      flex-direction: column;
      padding: var(--s2) var(--s3);
      background: var(--paper-dark);
      border-left: 3px solid #7A3B2E;
      text-decoration: none;
      color: inherit;
      transition: background 0.15s ease;
    }
    .secondary-link:hover {
      background: var(--paper);
    }
    .secondary-link strong {
      font-size: 1rem;
      color: var(--ink);
      margin-bottom: 2px;
    }
    .secondary-link span {
      font-size: 0.8125rem;
      color: var(--ink-light);
    }
  </style>
</BaseLayout>

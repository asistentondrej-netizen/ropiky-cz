---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pevnosti = await getCollection('pevnosti');

// Data pro klientský Leaflet
const points = pevnosti.map((p) => ({
  slug: p.id.replace(/\.json$|\.yml$|\.yaml$/, ''),
  title: p.data.title,
  code: p.data.code,
  line: p.data.line,
  region: p.data.region,
  type: p.data.type,
  state: p.data.state,
  built: p.data.built ?? '',
  description: p.data.description,
  photo: p.data.photos?.[0]?.url ?? null,
  lat: p.data.location.lat,
  lon: p.data.location.lon,
}));

// Sezbírej unikátní typy a stavy pro filtry
const uniqueTypes = [...new Set(points.map((p) => p.type))].sort();
const uniqueStates = [...new Set(points.map((p) => p.state))].sort();

// Štítky pro UI
const typeLabels: Record<string, string> = {
  'delostrelecka-tvrz': 'Dělostřelecká tvrz',
  'pechotni-srub': 'Pěchotní srub',
  'lo-vz-37': 'Řopík (LO vz. 37)',
  'lo-vz-36': 'LO vz. 36',
  'objekt-vz-36': 'Objekt vz. 36',
};

const stateLabels: Record<string, string> = {
  muzeum: 'Muzeum',
  pristupny: 'Volně přístupný',
  zachovaly: 'Zachovalý',
  zavreny: 'Uzavřený',
  rozpadly: 'Rozpadlý',
  zničeny: 'Zničený',
  neznamy: 'Neznámý stav',
};
---

<BaseLayout
  title="Mapa pevností"
  description="Interaktivní mapa všech dokumentovaných objektů československého opevnění 1935–1938. Filtrujte podle typu a stavu."
>
  <header class="catalog-header">
    <div class="container">
      <div class="article-hero__breadcrumb" style="margin-bottom: var(--s3);">
        <a href="/">Úvod</a> / <span>Mapa</span>
      </div>
      <h1>Mapa pevností</h1>
      <p class="article-hero__lead" style="margin-top: var(--s3);">
        {points.length} dokumentovaných objektů ŘOP. Klikněte na bod pro detail, použijte filtry pro zúžení výběru.
      </p>
    </div>
  </header>

  <section style="padding-top: var(--s4); padding-bottom: var(--s5);">
    <div class="container">

      <!-- Filtry -->
      <div class="map-filters" id="map-filters">
        <div class="filter-group">
          <span class="filter-label">Typ:</span>
          <button class="filter-btn is-active" data-filter="type" data-value="all">
            Všechny ({points.length})
          </button>
          {uniqueTypes.map((t) => {
            const count = points.filter((p) => p.type === t).length;
            return (
              <button class="filter-btn" data-filter="type" data-value={t}>
                {typeLabels[t] ?? t} ({count})
              </button>
            );
          })}
        </div>

        <div class="filter-group">
          <span class="filter-label">Stav:</span>
          <button class="filter-btn is-active" data-filter="state" data-value="all">
            Všechny
          </button>
          {uniqueStates.map((s) => {
            const count = points.filter((p) => p.state === s).length;
            return (
              <button class="filter-btn" data-filter="state" data-value={s}>
                {stateLabels[s] ?? s} ({count})
              </button>
            );
          })}
        </div>
      </div>

      <p class="map-note">
        <strong>Pozn.:</strong> Katalog obsahuje {points.length} objektů (stav duben 2026). Většina bodů pochází z dat OpenStreetMap (CC BY-SA)
        a obsahuje zatím pouze GPS a typovou klasifikaci — popis, fotografie a historie se postupně doplňují.
        Mapa používá clustering; rozkliknutím shluku se rozpadá na jednotlivé objekty.
      </p>

      <!-- Mapa -->
      <div id="map" style="height: 70vh; min-height: 540px; border: 1px solid var(--line); background: var(--paper-dark); position: relative;">
        <div id="map-search" class="map-search">
          <input
            type="search"
            id="map-search-input"
            class="map-search__input"
            placeholder="Najdi město nebo objekt (např. Mikulov, B-S 6, Bouda)…"
            autocomplete="off"
            aria-label="Vyhledávání v mapě"
          />
          <button type="button" id="map-search-clear" class="map-search__clear" aria-label="Vymazat" hidden>×</button>
          <div id="map-search-results" class="map-search__results" hidden></div>
        </div>
        <div id="map-counter" class="map-counter">Zobrazeno: <strong id="visible-count">{points.length}</strong> z {points.length}</div>
      </div>

      <!-- Legenda -->
      <div class="map-legend">
        <span class="legend-item"><span class="legend-dot" style="background:#7A3B2E;"></span> Dělostřelecká tvrz</span>
        <span class="legend-item"><span class="legend-dot" style="background:#8B5A3C;"></span> Pěchotní srub</span>
        <span class="legend-item"><span class="legend-dot" style="background:#5A6B4F;"></span> Řopík (LO vz. 37)</span>
        <span class="legend-item"><span class="legend-dot" style="background:#7A8270;"></span> LO vz. 36</span>
        <span class="legend-divider">|</span>
        <span class="legend-item"><span class="legend-ring" style="border-color:#2D5F3F;"></span> Muzeum (rámeček)</span>
      </div>

      <p style="font-size: 0.8125rem; color: var(--ink-light); margin-top: var(--s3); font-style: italic;">
        Mapové podklady: © <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> přispěvatelé.
        Data o objektech: ropiky.cz a uvedené zdroje.
      </p>

    </div>
  </section>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin="" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin="" is:inline></script>
  <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js" is:inline></script>

  <style>
    .map-filters {
      background: var(--paper-dark);
      border: 1px solid var(--line);
      padding: var(--s3);
      margin-bottom: var(--s3);
      display: flex;
      flex-direction: column;
      gap: var(--s2);
    }
    .filter-group {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }
    .filter-label {
      font-weight: 600;
      font-size: 0.875rem;
      color: var(--ink);
      min-width: 60px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .filter-btn {
      background: var(--paper);
      border: 1px solid var(--line);
      padding: 6px 12px;
      font-size: 0.8125rem;
      font-family: inherit;
      color: var(--ink);
      cursor: pointer;
      transition: all 0.15s ease;
      border-radius: 0;
    }
    .filter-btn:hover {
      background: var(--paper-dark);
      border-color: var(--accent, #7A3B2E);
    }
    .filter-btn.is-active {
      background: var(--accent, #7A3B2E);
      color: white;
      border-color: var(--accent, #7A3B2E);
    }
    .map-counter {
      position: absolute;
      bottom: 18px;
      left: 12px;
      z-index: 400;
      background: rgba(255,255,255,0.95);
      border: 1px solid var(--line);
      padding: 6px 12px;
      font-size: 0.8125rem;
      font-family: monospace;
      color: var(--ink);
      pointer-events: none;
    }

    /* Vyhledávání v mapě */
    .map-search {
      position: absolute;
      top: 12px;
      left: 12px;
      z-index: 500;
      width: min(380px, calc(100% - 24px));
      background: rgba(255,255,255,0.98);
      border: 1px solid var(--line);
      box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    }
    .map-search__input {
      width: 100%;
      box-sizing: border-box;
      padding: 10px 36px 10px 14px;
      border: 0;
      font-size: 0.9375rem;
      font-family: inherit;
      color: var(--ink);
      background: transparent;
      outline: none;
    }
    .map-search__input::placeholder {
      color: var(--ink-light);
      font-size: 0.875rem;
    }
    .map-search__input:focus {
      background: rgba(122, 59, 46, 0.03);
    }
    .map-search__clear {
      position: absolute;
      right: 6px;
      top: 50%;
      transform: translateY(-50%);
      width: 26px;
      height: 26px;
      background: transparent;
      border: 0;
      font-size: 1.25rem;
      line-height: 1;
      color: var(--ink-light);
      cursor: pointer;
      padding: 0;
    }
    .map-search__clear:hover { color: var(--accent, #7A3B2E); }
    .map-search__results {
      margin: 0;
      padding: 0;
      max-height: min(60vh, 420px);
      overflow-y: auto;
      border-top: 1px solid var(--line);
    }
    .map-search__section {
      padding: 6px 14px 4px;
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--ink-light);
      background: var(--paper-dark);
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .map-search__section-loading::after {
      content: ' (načítám…)';
      font-weight: 400;
      text-transform: none;
      letter-spacing: 0;
      font-style: italic;
      opacity: 0.7;
    }
    .map-search__item {
      padding: 8px 14px;
      cursor: pointer;
      border-bottom: 1px solid rgba(0,0,0,0.04);
      font-size: 0.875rem;
      color: var(--ink);
      line-height: 1.35;
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }
    .map-search__item:last-child { border-bottom: 0; }
    .map-search__item:hover,
    .map-search__item.is-focused {
      background: rgba(122, 59, 46, 0.08);
    }
    .map-search__icon {
      flex: 0 0 auto;
      font-size: 1rem;
      line-height: 1.2;
      margin-top: 1px;
      opacity: 0.75;
    }
    .map-search__body {
      flex: 1 1 auto;
      min-width: 0;
    }
    .map-search__item-title {
      font-weight: 600;
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .map-search__item-meta {
      font-size: 0.75rem;
      color: var(--ink-light);
      font-family: monospace;
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .map-search__empty {
      padding: 12px 14px;
      font-size: 0.8125rem;
      color: var(--ink-light);
      font-style: italic;
    }
    .map-search__hint {
      padding: 10px 14px;
      font-size: 0.75rem;
      color: var(--ink-light);
      font-style: italic;
      border-top: 1px dashed rgba(0,0,0,0.08);
      background: rgba(0,0,0,0.015);
    }
    .map-note {
      margin: 0 0 var(--s3) 0;
      padding: var(--s3);
      background: var(--paper-dark);
      border-left: 3px solid #7A3B2E;
      font-size: 0.875rem;
      color: var(--ink-light);
      line-height: 1.6;
    }
    .map-note strong { color: var(--ink); }
    .map-note a { color: #7A3B2E; font-weight: 600; }
    .map-legend {
      margin-top: var(--s3);
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px;
      font-size: 0.8125rem;
      color: var(--ink-light);
    }
    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .legend-dot {
      display: inline-block;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      border: 2px solid white;
      box-shadow: 0 0 0 1px #444;
    }
    .legend-ring {
      display: inline-block;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      border: 3px solid;
      background: white;
    }
    .legend-divider {
      color: var(--line);
    }

    /* Popup styling */
    .leaflet-popup-content {
      margin: 0;
      width: 260px !important;
    }
    .leaflet-popup-content-wrapper {
      border-radius: 0;
      padding: 0;
    }
    .popup-card {
      font-family: inherit;
    }
    .popup-card__photo {
      width: 100%;
      height: 140px;
      object-fit: cover;
      display: block;
      background: var(--paper-dark);
    }
    .popup-card__photo--placeholder {
      width: 100%;
      height: 60px;
      background: var(--paper-dark);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--ink-light);
      font-size: 0.75rem;
      font-style: italic;
    }
    .popup-card__body {
      padding: 12px;
    }
    .popup-card__title {
      margin: 0 0 4px;
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.3;
    }
    .popup-card__code {
      font-family: monospace;
      font-size: 0.75rem;
      color: #7A3B2E;
      letter-spacing: 0.05em;
    }
    .popup-card__meta {
      margin: 8px 0 0;
      font-size: 0.75rem;
      color: var(--ink-light);
      line-height: 1.5;
    }
    .popup-card__desc {
      margin: 8px 0;
      font-size: 0.8125rem;
      color: var(--ink);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .popup-card__link {
      display: inline-block;
      margin-top: 6px;
      font-size: 0.8125rem;
      font-weight: 600;
      color: #7A3B2E;
      text-decoration: none;
    }
    .popup-card__link:hover {
      text-decoration: underline;
    }
    .popup-card__badge {
      display: inline-block;
      padding: 2px 6px;
      font-size: 0.6875rem;
      background: var(--paper-dark);
      color: var(--ink);
      margin-right: 4px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .popup-card__badge--muzeum { background: #2D5F3F; color: white; }
    .popup-card__badge--pristupny { background: #5A6B4F; color: white; }
    .popup-card__badge--zavreny { background: #8B6F47; color: white; }

    /* Cluster marker — sjednocený design s ŘOP paletou */
    .cluster-marker {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: #7A3B2E;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 3px solid white;
      box-shadow: 0 1px 4px rgba(0,0,0,0.4);
      font-weight: 700;
      font-size: 0.875rem;
      font-family: monospace;
    }
    .cluster-marker span { line-height: 1; }
    .marker-cluster { background: transparent !important; }
    .marker-cluster div { background: transparent !important; }

    /* Custom marker classes */
    .fort-marker {
      border-radius: 50%;
      border: 2px solid white;
      box-shadow: 0 1px 4px rgba(0,0,0,0.4);
    }
    .fort-marker--muzeum {
      box-shadow: 0 0 0 3px #2D5F3F, 0 1px 4px rgba(0,0,0,0.4);
    }

    @media (max-width: 640px) {
      .filter-group { flex-direction: column; align-items: flex-start; }
      .filter-label { min-width: auto; }
      .map-counter { font-size: 0.6875rem; padding: 4px 8px; bottom: 12px; left: 8px; }
      .map-search {
        top: 8px;
        left: 8px;
        right: 8px;
        width: auto;
      }
      .map-search__input { font-size: 16px; padding: 8px 32px 8px 12px; }
      .map-search__item { padding: 10px 14px; font-size: 0.9375rem; }
    }
  </style>

  <script define:vars={{ points, typeLabels, stateLabels }}>
    window.addEventListener('load', () => {
      if (typeof L === 'undefined') {
        console.error('Leaflet failed to load');
        return;
      }

      // ---- Mapa ----
      const map = L.map('map', { scrollWheelZoom: false, zoomControl: false }).setView([49.8, 15.5], 7);
      // Zoom ovládání vpravo nahoře — uvolní levý horní roh pro vyhledávání
      L.control.zoom({ position: 'topright' }).addTo(map);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 18,
        attribution: '© OpenStreetMap',
      }).addTo(map);

      // Povolit scroll-zoom po kliknutí (UX)
      map.on('click', () => map.scrollWheelZoom.enable());
      map.on('blur', () => map.scrollWheelZoom.disable());

      // ---- Color paleta ----
      const typeColors = {
        'delostrelecka-tvrz': '#7A3B2E',
        'pechotni-srub': '#8B5A3C',
        'lo-vz-37': '#5A6B4F',
        'lo-vz-36': '#7A8270',
        'objekt-vz-36': '#7A8270',
      };

      // ---- Tvorba markeru ----
      function createMarker(p) {
        const color = typeColors[p.type] || '#444';
        const isMuseum = p.state === 'muzeum';
        const size = p.type === 'delostrelecka-tvrz' ? 18 : (p.type === 'pechotni-srub' ? 14 : 11);
        const ringStyle = isMuseum ? `box-shadow: 0 0 0 3px #2D5F3F, 0 1px 4px rgba(0,0,0,0.4);` : '';

        const icon = L.divIcon({
          className: '',
          html: `<div class="fort-marker ${isMuseum ? 'fort-marker--muzeum' : ''}" style="width:${size}px;height:${size}px;background:${color};${ringStyle}"></div>`,
          iconSize: [size + 4, size + 4],
          iconAnchor: [(size + 4) / 2, (size + 4) / 2],
        });

        const marker = L.marker([p.lat, p.lon], { icon });

        // Popup HTML
        const photoHtml = p.photo
          ? `<img class="popup-card__photo" src="${p.photo}" alt="${p.title}" loading="lazy" />`
          : `<div class="popup-card__photo--placeholder">Foto zatím není dostupné</div>`;

        const stateLabel = stateLabels[p.state] || p.state;
        const stateClass = `popup-card__badge popup-card__badge--${p.state}`;
        const typeLabel = typeLabels[p.type] || p.type;

        const popupHtml = `
          <div class="popup-card">
            ${photoHtml}
            <div class="popup-card__body">
              <h3 class="popup-card__title">${p.title}</h3>
              <span class="popup-card__code">${p.code}</span>
              <p class="popup-card__desc">${p.description}</p>
              <div style="margin: 6px 0;">
                <span class="${stateClass}">${stateLabel}</span>
                <span class="popup-card__badge">${typeLabel}</span>
              </div>
              <p class="popup-card__meta">
                <strong>Úsek:</strong> ${p.line}<br/>
                <strong>Kraj:</strong> ${p.region}
                ${p.built ? `<br/><strong>Postaven:</strong> ${p.built}` : ''}
              </p>
              <a class="popup-card__link" href="/katalog/${p.slug}">Detail objektu →</a>
            </div>
          </div>
        `;

        marker.bindPopup(popupHtml, { maxWidth: 280, minWidth: 260 });
        marker._point = p; // pro filtraci
        return marker;
      }

      const allMarkers = points.map(createMarker);

      // ---- Cluster group (řeší výkon pro 6000+ bodů) ----
      const clusterGroup = (typeof L.markerClusterGroup === 'function')
        ? L.markerClusterGroup({
            chunkedLoading: true,
            spiderfyOnMaxZoom: true,
            showCoverageOnHover: false,
            maxClusterRadius: 55,
            disableClusteringAtZoom: 14,
            iconCreateFunction: function (cluster) {
              const n = cluster.getChildCount();
              const size = n < 10 ? 32 : (n < 100 ? 40 : 48);
              return L.divIcon({
                html: '<div class="cluster-marker"><span>' + n + '</span></div>',
                className: 'marker-cluster',
                iconSize: [size, size],
              });
            },
          })
        : L.layerGroup();

      allMarkers.forEach((m) => clusterGroup.addLayer(m));
      clusterGroup.addTo(map);

      // Auto-fit
      const bounds = points.map((p) => [p.lat, p.lon]);
      if (bounds.length > 0) map.fitBounds(bounds, { padding: [40, 40] });

      // ---- Filtrace ----
      const filterState = { type: 'all', state: 'all' };
      const counterEl = document.getElementById('visible-count');

      function applyFilters() {
        clusterGroup.clearLayers();
        let visible = 0;
        const toAdd = [];
        allMarkers.forEach((m) => {
          const p = m._point;
          const matchType = filterState.type === 'all' || p.type === filterState.type;
          const matchState = filterState.state === 'all' || p.state === filterState.state;
          if (matchType && matchState) {
            toAdd.push(m);
            visible++;
          }
        });
        clusterGroup.addLayers(toAdd);
        if (counterEl) counterEl.textContent = visible;
      }

      // Click handlers
      document.querySelectorAll('.filter-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const filter = btn.dataset.filter;
          const value = btn.dataset.value;

          // Deaktivuj sourozence ve stejné skupině
          btn.parentElement.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');

          filterState[filter] = value;
          applyFilters();
        });
      });

      // ---- Vyhledávání (dvousekční: Místa + Objekty ŘOP) ----
      const searchInput = document.getElementById('map-search-input');
      const searchClear = document.getElementById('map-search-clear');
      const searchResults = document.getElementById('map-search-results');
      const MAX_FORT_RESULTS = 8;
      const MAX_PLACE_RESULTS = 4;
      const MIN_QUERY_LEN = 2;
      const GEOCODE_MIN_QUERY_LEN = 3;
      const GEOCODE_DEBOUNCE_MS = 350;

      // Normalizace — strip diakritiky, lowercase
      function normalize(s) {
        return (s || '')
          .toString()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        })[c]);
      }

      // Index katalogu — předpočítaný
      const searchIndex = points.map((p) => ({
        p,
        hay: normalize(`${p.title} ${p.code} ${p.line} ${p.region}`),
        title_n: normalize(p.title),
        code_n: normalize(p.code),
      }));

      // Stav
      let flatItems = [];        // [{kind: 'place'|'fort', data: ...}] — v pořadí, jak se renderují
      let focusedIdx = -1;
      let lastQuery = '';
      let geocodeAbortCtrl = null;
      let geocodeTimer = null;
      let placeCache = Object.create(null); // dotaz → pole míst

      // ---- Lokální fort search ----
      function searchForts(q) {
        const qn = normalize(q);
        if (!qn || qn.length < MIN_QUERY_LEN) return [];
        const scored = [];
        for (const entry of searchIndex) {
          if (!entry.hay.includes(qn)) continue;
          let score = 100;
          if (entry.title_n === qn || entry.code_n === qn) score = 0;
          else if (entry.title_n.startsWith(qn) || entry.code_n.startsWith(qn)) score = 10;
          else if (entry.hay.startsWith(qn)) score = 20;
          scored.push({ p: entry.p, score: score + entry.p.title.length * 0.01 });
          if (scored.length > 400) break;
        }
        scored.sort((a, b) => a.score - b.score);
        return scored.slice(0, MAX_FORT_RESULTS).map((s) => s.p);
      }

      // ---- Render ----
      function render({ places, forts, placesLoading, query }) {
        flatItems = [];
        const parts = [];

        // Sekce: Místa
        if (places && places.length > 0) {
          parts.push(`<div class="map-search__section">Místa</div>`);
          places.forEach((pl) => {
            const i = flatItems.length;
            flatItems.push({ kind: 'place', data: pl });
            const meta = [pl.kind_label, pl.region_label].filter(Boolean).join(' · ');
            parts.push(`
              <div class="map-search__item" data-idx="${i}" role="option">
                <span class="map-search__icon">📍</span>
                <span class="map-search__body">
                  <span class="map-search__item-title">${escapeHtml(pl.display_name)}</span>
                  ${meta ? `<span class="map-search__item-meta">${escapeHtml(meta)}</span>` : ''}
                </span>
              </div>
            `);
          });
        } else if (placesLoading && query.length >= GEOCODE_MIN_QUERY_LEN) {
          parts.push(`<div class="map-search__section map-search__section-loading">Místa</div>`);
        }

        // Sekce: Objekty ŘOP
        if (forts && forts.length > 0) {
          parts.push(`<div class="map-search__section">Objekty ŘOP</div>`);
          forts.forEach((p) => {
            const i = flatItems.length;
            flatItems.push({ kind: 'fort', data: p });
            const typeLabel = typeLabels[p.type] || p.type;
            const metaParts = [p.line, p.region].filter((x) => x && x !== 'Neurčeno').join(' · ');
            const meta = typeLabel + (metaParts ? ' · ' + metaParts : '');
            parts.push(`
              <div class="map-search__item" data-idx="${i}" role="option">
                <span class="map-search__icon">🏛</span>
                <span class="map-search__body">
                  <span class="map-search__item-title">${escapeHtml(p.title)}</span>
                  <span class="map-search__item-meta">${escapeHtml(meta)}</span>
                </span>
              </div>
            `);
          });
        }

        if (parts.length === 0) {
          if (query.length < MIN_QUERY_LEN) {
            searchResults.hidden = true;
            searchResults.innerHTML = '';
            focusedIdx = -1;
            return;
          }
          parts.push('<div class="map-search__empty">Nic nenalezeno</div>');
        }

        // Nápověda dole
        if (flatItems.length > 0) {
          parts.push(`<div class="map-search__hint">↑↓ vybrat, Enter potvrdit, Esc zavřít</div>`);
        }

        searchResults.innerHTML = parts.join('');
        searchResults.hidden = false;
        focusedIdx = -1;
      }

      // ---- Nominatim geocoding ----
      function geocodePlace(query, onDone) {
        const cacheKey = normalize(query);
        if (placeCache[cacheKey]) {
          onDone(placeCache[cacheKey]);
          return;
        }
        if (geocodeAbortCtrl) geocodeAbortCtrl.abort();
        geocodeAbortCtrl = new AbortController();

        // Nominatim: CZ+SK, omezený limit, addressdetails pro kontext
        const url = 'https://nominatim.openstreetmap.org/search?'
          + 'format=json'
          + '&limit=' + MAX_PLACE_RESULTS
          + '&addressdetails=1'
          + '&countrycodes=cz,sk'
          + '&accept-language=cs'
          + '&q=' + encodeURIComponent(query);

        fetch(url, {
          signal: geocodeAbortCtrl.signal,
          headers: { 'Accept': 'application/json' },
        })
          .then((r) => r.ok ? r.json() : [])
          .then((data) => {
            const out = (Array.isArray(data) ? data : [])
              .filter((x) => x && x.lat && x.lon)
              .map((x) => {
                const addr = x.address || {};
                const city = addr.city || addr.town || addr.village || addr.municipality || addr.hamlet;
                const region = addr.state || addr.region || addr.county;
                const country = addr.country;
                // Primární label: krátký (město / obec / ulice) bez úplné adresy
                let label;
                if (city && (x.type === 'city' || x.type === 'town' || x.type === 'village' || x.type === 'administrative')) {
                  label = city;
                } else if (x.name) {
                  label = x.name;
                } else {
                  label = (x.display_name || '').split(',')[0];
                }
                return {
                  lat: parseFloat(x.lat),
                  lon: parseFloat(x.lon),
                  bbox: x.boundingbox
                    ? x.boundingbox.map(parseFloat) // [south, north, west, east]
                    : null,
                  display_name: label,
                  kind_label: x.type ? (x.type.charAt(0).toUpperCase() + x.type.slice(1)) : '',
                  region_label: [region, country].filter(Boolean).join(', '),
                  osm_type: x.osm_type,
                };
              });
            placeCache[cacheKey] = out;
            onDone(out);
          })
          .catch((err) => {
            if (err.name === 'AbortError') return;
            // Síťová chyba → tiše jen katalog
            onDone([]);
          });
      }

      // ---- Hlavní search orchestrátor ----
      function runSearch(query) {
        lastQuery = query;
        const q = normalize(query);
        searchClear.hidden = !query;

        if (!q || q.length < MIN_QUERY_LEN) {
          searchResults.hidden = true;
          searchResults.innerHTML = '';
          flatItems = [];
          focusedIdx = -1;
          if (geocodeAbortCtrl) geocodeAbortCtrl.abort();
          clearTimeout(geocodeTimer);
          return;
        }

        const forts = searchForts(query);

        // Okamžitě zobraz katalog + "načítám místa"
        render({
          places: placeCache[q] || [],
          forts,
          placesLoading: !placeCache[q] && q.length >= GEOCODE_MIN_QUERY_LEN,
          query: q,
        });

        // Geocoding s debounce — jen když query má smysl
        clearTimeout(geocodeTimer);
        if (q.length >= GEOCODE_MIN_QUERY_LEN && !placeCache[q]) {
          geocodeTimer = setTimeout(() => {
            geocodePlace(query, (places) => {
              // Pokud se mezitím query změnila, render se tak jako tak přepíše později
              if (normalize(lastQuery) !== q) return;
              render({
                places,
                forts: searchForts(lastQuery),
                placesLoading: false,
                query: q,
              });
            });
          }, GEOCODE_DEBOUNCE_MS);
        }
      }

      // ---- Výběr výsledku ----
      function selectItem(item) {
        if (!item) return;
        searchResults.hidden = true;
        searchInput.blur();

        if (item.kind === 'place') {
          const pl = item.data;
          if (pl.bbox && pl.bbox.length === 4) {
            // [south, north, west, east] → Leaflet: [[south, west], [north, east]]
            const bounds = [[pl.bbox[0], pl.bbox[2]], [pl.bbox[1], pl.bbox[3]]];
            map.flyToBounds(bounds, { padding: [30, 30], maxZoom: 14, duration: 0.8 });
          } else {
            map.flyTo([pl.lat, pl.lon], 13, { duration: 0.8 });
          }
          return;
        }

        // kind === 'fort'
        const p = item.data;
        const matchType = filterState.type === 'all' || p.type === filterState.type;
        const matchState = filterState.state === 'all' || p.state === filterState.state;
        if (!matchType || !matchState) {
          filterState.type = 'all';
          filterState.state = 'all';
          document.querySelectorAll('.filter-btn').forEach((b) => {
            b.classList.toggle('is-active', b.dataset.value === 'all');
          });
          applyFilters();
        }
        const marker = allMarkers.find((m) => m._point.slug === p.slug);
        if (!marker) return;
        if (clusterGroup.zoomToShowLayer) {
          clusterGroup.zoomToShowLayer(marker, () => marker.openPopup());
        } else {
          map.setView([p.lat, p.lon], 15);
          marker.openPopup();
        }
      }

      // ---- Klávesnice / myš ----
      let inputDebounceTimer;
      searchInput.addEventListener('input', (e) => {
        clearTimeout(inputDebounceTimer);
        const v = e.target.value;
        // Katalog renderuj rychle (120 ms), geocoding má vlastní pomalejší debounce
        inputDebounceTimer = setTimeout(() => runSearch(v), 120);
      });

      searchInput.addEventListener('focus', () => {
        if (flatItems.length > 0 || (searchResults.innerHTML && searchInput.value)) {
          searchResults.hidden = false;
        }
      });

      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (flatItems.length === 0) return;
          focusedIdx = Math.min(focusedIdx + 1, flatItems.length - 1);
          if (focusedIdx < 0) focusedIdx = 0;
          updateFocused();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          focusedIdx = Math.max(focusedIdx - 1, -1);
          updateFocused();
        } else if (e.key === 'Enter') {
          e.preventDefault();
          const target = focusedIdx >= 0 ? flatItems[focusedIdx] : flatItems[0];
          if (target) selectItem(target);
        } else if (e.key === 'Escape') {
          searchResults.hidden = true;
          searchInput.blur();
        }
      });

      function updateFocused() {
        searchResults.querySelectorAll('.map-search__item').forEach((el, i) => {
          el.classList.toggle('is-focused', i === focusedIdx);
          if (i === focusedIdx) el.scrollIntoView({ block: 'nearest' });
        });
      }

      searchResults.addEventListener('click', (e) => {
        const item = e.target.closest('.map-search__item');
        if (!item) return;
        const idx = parseInt(item.dataset.idx, 10);
        if (!isNaN(idx)) selectItem(flatItems[idx]);
      });

      searchClear.addEventListener('click', () => {
        searchInput.value = '';
        runSearch('');
        searchInput.focus();
      });

      // Zavři dropdown při kliku mimo
      document.addEventListener('click', (e) => {
        if (!e.target.closest('#map-search')) {
          searchResults.hidden = true;
        }
      });
    });
  </script>
</BaseLayout>

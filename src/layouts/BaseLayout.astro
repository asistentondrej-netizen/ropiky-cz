---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Československé opevnění 1935–1938: referenční portál s katalogem přes 6 000 objektů — řopíky, pěchotní sruby, dělostřelecké tvrze. Interaktivní mapa, historie, fotogalerie.',
  image = '/img/og-default.png',
  noIndex = false,
} = Astro.props;

const fullTitle =
  title === 'Ropiky.cz' || title.startsWith('Ropiky.cz')
    ? title
    : `${title} — Ropiky.cz`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();

// --- Analytics a Search Console verifikace ---
// Cloudflare Web Analytics: vloží se jen v produkci a pouze na indexovatelných stránkách.
const isProd = import.meta.env.PROD;

// Token získáš v Cloudflare dashboardu → Analytics & Logs → Web Analytics → Add a site
// Po přidání ropiky.cz se ti zobrazí snippet s tokenem, zkopíruj ho SEM:
const cfAnalyticsToken = 'cfdb50c474944453b00400a6fc4de586';

// Search Console verifikační meta-tagy:
const gscVerification = 'CAgiJSMB1Mgz6mqlr6XEdOQP_gdsPe3bPFnrNoIQraY'; // Google Search Console
const bingVerification = ''; // msvalidate.01 — doplnit po registraci
const seznamVerification = ''; // seznam-wmt — doplnit po registraci
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    {/* Search Console verifikace */}
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}
    {seznamVerification && <meta name="seznam-wmt" content={seznamVerification} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="Ropiky.cz" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Ropiky.cz" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400..700;1,400..700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {/* Cloudflare Web Analytics — zdarma, bez cookies, GDPR-friendly. Jen produkce.
        Opt-out: návštěva https://www.ropiky.cz/?exclude-me=1 nastaví cookie, která
        na tomto prohlížeči vypne načítání beaconu (vlastní/testovací návštěvy se
        tak nezapočítávají do statistik). Odvolání: ?exclude-me=0 */}
    {isProd && !noIndex && cfAnalyticsToken && (
      <script is:inline set:html={`
        (function () {
          try {
            var qs = new URLSearchParams(location.search);
            var action = qs.get('exclude-me');
            var showBanner = null;

            if (action === '1') {
              document.cookie = 'no_analytics=1; max-age=63072000; path=/; domain=.ropiky.cz; SameSite=Lax';
              showBanner = 'on';
            }
            if (action === '0') {
              document.cookie = 'no_analytics=; max-age=0; path=/; domain=.ropiky.cz';
              showBanner = 'off';
            }

            var optedOut = document.cookie.indexOf('no_analytics=1') !== -1;
            if (action === 'check') {
              showBanner = optedOut ? 'on' : 'off';
            }

            if (showBanner) {
              document.addEventListener('DOMContentLoaded', function () {
                var bar = document.createElement('div');
                bar.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:99999;padding:14px 20px;text-align:center;font:600 15px -apple-system,BlinkMacSystemFont,sans-serif;background:' + (showBanner === 'on' ? '#2d7a2d' : '#b04020') + ';color:#fff;box-shadow:0 2px 8px rgba(0,0,0,.2)';
                bar.textContent = showBanner === 'on'
                  ? '✓ Analytics vypnuté na tomto prohlížeči. Tvoje návštěvy se nezapočítávají do statistik.'
                  : '✗ Analytics jsou zapnuté (opt-out není aktivní). Navštiv /?exclude-me=1 pro vyloučení.';
                document.body.insertBefore(bar, document.body.firstChild);
                setTimeout(function () { bar.style.transition = 'opacity .5s'; bar.style.opacity = '0'; setTimeout(function () { bar.remove(); }, 500); }, 6000);
              });
            }

            if (optedOut) return;
            var s = document.createElement('script');
            s.defer = true;
            s.src = 'https://static.cloudflareinsights.com/beacon.min.js';
            s.setAttribute('data-cf-beacon', '{"token":"${cfAnalyticsToken}"}');
            document.head.appendChild(s);
          } catch (e) {}
        })();
      `} />
    )}
  </head>
  <body>
    <a href="#main" class="visually-hidden">Přeskočit na obsah</a>
    <Header />
    <main id="main" data-pagefind-body>
      <slot />
    </main>
    <Footer />

    <style>
      .visually-hidden {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap; border: 0;
      }
      .visually-hidden:focus {
        position: static;
        width: auto; height: auto;
        margin: 0; clip: auto;
        white-space: normal;
        background: var(--khaki); color: var(--paper);
        padding: var(--s2);
      }
    </style>
  </body>
</html>
